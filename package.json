{
  "name": "html-live-viewer",
  "displayName": "HTML Live Viewer",
  "description": "HTML 파일이나 폴더를 열면 실시간 렌더링 결과를 웹페이지처럼 보여주는 미리보기/뷰어 확장",
  "version": "1.2.3",
  "publisher": "innohi",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/INNO-HI-Inc/html-live-viewer"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "html",
    "preview",
    "viewer",
    "live",
    "browser",
    "live server",
    "livereload",
    "live preview",
    "localhost",
    "mobile",
    "responsive"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:html"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "htmlViewer.openPreviewToSide",
        "title": "HTML: 미리보기 열기 (옆 패널)",
        "category": "HTML Live Viewer",
        "icon": "$(open-preview)"
      },
      {
        "command": "htmlViewer.openPreview",
        "title": "HTML: 미리보기 열기",
        "category": "HTML Live Viewer",
        "icon": "$(open-preview)"
      },
      {
        "command": "htmlViewer.refresh",
        "title": "HTML: 미리보기 새로고침",
        "category": "HTML Live Viewer",
        "icon": "$(refresh)"
      },
      {
        "command": "htmlViewer.openInBrowser",
        "title": "HTML: 브라우저에서 열기",
        "category": "HTML Live Viewer",
        "icon": "$(globe)"
      },
      {
        "command": "htmlViewer.copyUrl",
        "title": "HTML: 미리보기 URL 복사",
        "category": "HTML Live Viewer",
        "icon": "$(link)"
      },
      {
        "command": "htmlViewer.showConsole",
        "title": "HTML: 미리보기 콘솔 열기",
        "category": "HTML Live Viewer",
        "icon": "$(output)"
      },
      {
        "command": "htmlViewer.openSettings",
        "title": "HTML: 설정 열기",
        "category": "HTML Live Viewer",
        "icon": "$(gear)"
      },
      {
        "command": "htmlViewer.showQr",
        "title": "HTML: 휴대폰으로 보기 (QR)",
        "category": "HTML Live Viewer",
        "icon": "$(device-mobile)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "htmlViewer.openPreviewToSide",
          "when": "resourceLangId == html || resourceExtname == .html || resourceExtname == .htm",
          "group": "navigation"
        },
        {
          "command": "htmlViewer.openInBrowser",
          "when": "htmlViewer.previewActive",
          "group": "navigation"
        },
        {
          "command": "htmlViewer.openSettings",
          "when": "htmlViewer.previewActive",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "htmlViewer.openPreviewToSide",
          "when": "resourceLangId == html || resourceExtname == .html || resourceExtname == .htm",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "htmlViewer.openPreview",
          "when": "resourceExtname == .html || resourceExtname == .htm",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "htmlViewer.refresh",
          "when": "htmlViewer.previewActive"
        },
        {
          "command": "htmlViewer.openInBrowser",
          "when": "htmlViewer.previewActive"
        },
        {
          "command": "htmlViewer.copyUrl",
          "when": "htmlViewer.previewActive"
        },
        {
          "command": "htmlViewer.showConsole",
          "when": "htmlViewer.previewActive"
        },
        {
          "command": "htmlViewer.openSettings"
        },
        {
          "command": "htmlViewer.showQr"
        }
      ]
    },
    "keybindings": [
      {
        "command": "htmlViewer.openPreviewToSide",
        "key": "ctrl+shift+1",
        "mac": "cmd+shift+1",
        "when": "editorLangId == html"
      }
    ],
    "configuration": {
      "title": "HTML Live Viewer",
      "properties": {
        "htmlViewer.autoRefresh": {
          "type": "string",
          "enum": [
            "onType",
            "onSave",
            "off"
          ],
          "enumDescriptions": [
            "입력하는 즉시 새로고침 (저장 시에도 새로고침)",
            "파일을 저장할 때만 새로고침",
            "수동 새로고침만"
          ],
          "default": "onType",
          "description": "미리보기를 언제 자동으로 새로고침할지 설정합니다."
        },
        "htmlViewer.refreshDelay": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "description": "onType 모드에서 마지막 입력 후 새로고침까지 대기 시간(ms)."
        },
        "htmlViewer.followActiveEditor": {
          "type": "boolean",
          "default": true,
          "description": "다른 HTML 파일로 포커스를 옮기면 미리보기 대상도 자동으로 따라갑니다."
        },
        "htmlViewer.autoOpenOnHtml": {
          "type": "boolean",
          "default": true,
          "description": "HTML 파일을 열면 미리보기를 자동으로 전체 탭에 엽니다."
        },
        "htmlViewer.autoOpenOnFolder": {
          "type": "boolean",
          "default": false,
          "description": "폴더를 열 때 워크스페이스에서 HTML(index.html 우선)을 찾아 자동으로 미리보기를 엽니다. (기본 꺼짐)"
        },
        "htmlViewer.forwardConsole": {
          "type": "boolean",
          "default": true,
          "description": "미리보기 페이지의 console.* 출력과 자바스크립트 에러를 'HTML Preview Console' 출력 패널로 전달합니다."
        },
        "htmlViewer.showErrorOverlay": {
          "type": "boolean",
          "default": true,
          "description": "자바스크립트 에러가 발생하면 미리보기 화면 하단에 빨간 배너로 표시합니다."
        },
        "htmlViewer.qualityChecks": {
          "type": "boolean",
          "default": false,
          "description": "페이지 로드 시 깨진 링크와 alt 없는 이미지를 점검해 'HTML Preview Console' 패널에 경고를 남깁니다."
        },
        "htmlViewer.spaFallback": {
          "type": "boolean",
          "default": false,
          "description": "확장자 없는 알 수 없는 경로 요청을 index.html로 응답합니다. 클라이언트 라우팅(SPA) 미리보기에 사용합니다."
        },
        "htmlViewer.port": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 65535,
          "description": "미리보기 서버 포트. 0이면 자동 할당. 지정 포트가 사용 중이면 자동 포트로 대체합니다."
        },
        "htmlViewer.allowNetworkPreview": {
          "type": "boolean",
          "default": false,
          "description": "⚠️ 미리보기 서버를 로컬 네트워크(0.0.0.0)에 공개합니다. 같은 Wi-Fi의 기기(휴대폰)에서 접속할 수 있으며, 워크스페이스 파일이 네트워크에 노출됩니다."
        },
        "htmlViewer.syncScroll": {
          "type": "boolean",
          "default": false,
          "description": "에디터를 스크롤하면 미리보기도 같은 비율로 스크롤합니다."
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package",
    "test": "node test/run-server-tests.js && node test/run-qr-tests.js && node test/run-tests.js"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1"
  },
  "homepage": "https://inno-hi-inc.github.io/html-live-viewer/",
  "bugs": {
    "url": "https://github.com/INNO-HI-Inc/html-live-viewer/issues"
  },
  "galleryBanner": {
    "color": "#1e0d06",
    "theme": "dark"
  }
}
